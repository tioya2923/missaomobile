      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#181818"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.missaonohuambo.app"
    },
    "android": {
      "package": "org.missaonohuambo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#181818"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-local-authentication",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "8df64736-c42f-45cb-b1e7-1b00d1ce33f5"
      }
    }
  }
}
